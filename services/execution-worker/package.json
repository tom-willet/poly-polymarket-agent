{
  "name": "@poly/execution-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @poly/trade-core build && pnpm --filter @poly/openclaw-control build",
    "build": "tsc -p tsconfig.json",
    "tick": "tsx src/cli.ts tick",
    "loop": "tsx src/cli.ts loop",
    "pretest": "pnpm --filter @poly/trade-core build && pnpm --filter @poly/openclaw-control build",
    "test": "node --import tsx --test ./test/*.test.ts"
  },
  "dependencies": {
    "@poly/openclaw-control": "workspace:*",
    "@poly/trade-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
