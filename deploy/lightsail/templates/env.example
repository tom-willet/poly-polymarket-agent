# Core OpenClaw settings
OPENCLAW_REF=main
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_TOKEN=replace-with-long-random-token
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=openai/gpt-5.2

# Optional billing key (if different from OPENAI_API_KEY)
# OPENAI_BILLING_API_KEY=replace-with-openai-billing-key

# Slack (Socket Mode)
SLACK_APP_TOKEN=xapp-1-replace-with-app-level-token
SLACK_BOT_TOKEN=xoxb-replace-with-bot-token
SLACK_DM_POLICY=open
SLACK_ALLOWED_USER_IDS_JSON=[]

# Budget guardrails
BUDGET_WARN_THRESHOLD_USD=8
BUDGET_HARD_CAP_USD=10
BUDGET_ENFORCEMENT_MODE=enforce
